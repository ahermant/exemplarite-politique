---
import type { Politicien } from '../lib/types';
import { getPartyColor, isCondamnation, isInculpation } from '../lib/types';

interface Props {
  politicien: Politicien;
}

const { politicien: p } = Astro.props;
const partyColor = getPartyColor(p.parti);
const initials = ((p.prenom?.[0] || '') + (p.nom?.[0] || '')).toUpperCase() || '?';
---

<a
  href={`/politique/${p.slug}`}
  class="card group flex flex-col overflow-hidden hover:border-zinc-300"
>
  <div class="relative p-6">
    <div class="flex items-start gap-4">
      <div
        class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-semibold text-sm"
        style={`background-color: ${partyColor}`}
      >
        {initials}
      </div>
      <div class="min-w-0 flex-1">
        <h3 class="font-semibold text-zinc-900 group-hover:text-blue-600 transition-colors truncate">
          {p.prenom} {p.nom}
        </h3>
        {p.parti && (
          <span class="inline-block mt-1 badge text-xs" style={`background-color: ${partyColor}15; color: ${partyColor}`}>
            {p.parti}
          </span>
        )}
        <p class="mt-1.5 text-sm text-zinc-500 truncate">{p.titreMandat || p.mandat || '—'}</p>
      </div>
    </div>

    <div class="mt-4 pt-4 border-t border-zinc-50 grid grid-cols-3 gap-2">
      <div class="text-center">
        <div class={`text-lg font-bold ${p.nbEnquetes > 0 ? 'text-blue-600' : 'text-zinc-300'}`}>
          {p.nbEnquetes}
        </div>
        <div class="text-[10px] text-zinc-400 uppercase tracking-wide">Enquêtes</div>
      </div>
      <div class="text-center">
        <div class={`text-lg font-bold ${p.nbInculpations > 0 ? 'text-amber-600' : 'text-zinc-300'}`}>
          {p.nbInculpations}
        </div>
        <div class="text-[10px] text-zinc-400 uppercase tracking-wide">Mises en examen</div>
      </div>
      <div class="text-center">
        <div class={`text-lg font-bold ${p.nbCondamnations > 0 ? 'text-red-600' : 'text-zinc-300'}`}>
          {p.nbCondamnations}
        </div>
        <div class="text-[10px] text-zinc-400 uppercase tracking-wide">Condamn.</div>
      </div>
    </div>
  </div>
</a>
