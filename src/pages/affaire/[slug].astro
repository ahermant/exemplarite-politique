---
import Layout from '../../components/Layout.astro';
import { getAffaires, getAffaireBySlug, getPoliticienById } from '../../lib/data';
import { getStatutLabel, getStatutVariant, getPartyColor, isCondamnation } from '../../lib/types';

export function getStaticPaths() {
  const affaires = getAffaires();
  return affaires.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const affaire = getAffaireBySlug(slug);

if (!affaire) {
  return new Response(null, { status: 302, headers: { Location: '/' } });
}

const politicien = getPoliticienById(affaire.politicienId);
const partyColor = getPartyColor(affaire.partiActuel);
const variantClass = getStatutVariant(affaire.statutCode);
const isC = isCondamnation(affaire.statutCode);

function formatDate(d) {
  if (!d) return null;
  try {
    const date = new Date(d);
    if (isNaN(date.getTime())) return d;
    return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch { return d; }
}

function formatMoney(n) {
  if (n == null || isNaN(n)) return null;
  return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);
}

function formatDuration(mois) {
  if (mois == null || isNaN(mois)) return null;
  if (mois >= 12) {
    const ans = Math.floor(mois / 12);
    const m = mois % 12;
    return `${ans} an${ans > 1 ? 's' : ''}${m > 0 ? ` ${m} mois` : ''}`;
  }
  return `${mois} mois`;
}
---

<Layout title={affaire.titre} description={affaire.description?.slice(0, 160)}>
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Back -->
      <a href={politicien ? `/politique/${politicien.slug}` : '/'} class="inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-900 transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        {politicien ? `Retour à ${politicien.prenom} ${politicien.nom}` : 'Retour'}
      </a>

      <!-- Affair Header -->
      <div class="card p-6 sm:p-8 mb-8">
        <div class="flex items-start justify-between gap-4 mb-4">
          <span class={`badge text-sm px-3 py-1 ${variantClass}`}>
            {getStatutLabel(affaire.statutCode)}
          </span>
        </div>

        <h1 class="text-2xl sm:text-3xl font-bold text-zinc-900 text-balance">
          {affaire.titre}
        </h1>

        <!-- Métadonnées -->
        <div class="flex flex-wrap gap-x-6 gap-y-3 mt-6 text-sm">
          {affaire.categorie && (
            <div>
              <span class="text-zinc-400">Catégorie</span>
              <p class="font-medium text-zinc-700">{affaire.categorie}</p>
            </div>
          )}
          {affaire.implication && (
            <div>
              <span class="text-zinc-400">Implication</span>
              <p class="font-medium text-zinc-700">{affaire.implication}</p>
            </div>
          )}
          {affaire.lieeAuMandat && (
            <div>
              <span class="text-zinc-400">Liée au mandat</span>
              <p class="font-medium text-zinc-700">{affaire.lieeAuMandat === 'oui' ? 'Oui' : 'Non'}</p>
            </div>
          )}
        </div>
      </div>

      <!-- Politician Link -->
      {politicien && (
        <div class="card p-5 mb-8 flex items-center gap-4">
          <div
            class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-white font-semibold text-xs"
            style={`background-color: ${partyColor}`}
          >
            {((politicien.prenom?.[0] || '') + (politicien.nom?.[0] || '')).toUpperCase() || '?'}
          </div>
          <div>
            <p class="text-xs text-zinc-400">Élu concerné</p>
            <a href={`/politique/${politicien.slug}`} class="font-semibold text-zinc-900 hover:text-blue-600 transition-colors">
              {politicien.prenom} {politicien.nom}
            </a>
            {affaire.partiActuel && (
              <span class="ml-2 badge text-xs" style={`background-color: ${partyColor}15; color: ${partyColor}`}>
                {affaire.partiActuel}
              </span>
            )}
          </div>
        </div>
      )}

      <!-- Dates Timeline -->
      <div class="card p-6 mb-8">
        <h2 class="text-lg font-semibold text-zinc-900 mb-4">Chronologie</h2>
        <div class="space-y-4">
          {affaire.dateFaits && (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-32 text-sm text-zinc-400">Faits</div>
              <div class="text-sm text-zinc-700">{affaire.dateFaits}</div>
            </div>
          )}
          {formatDate(affaire.dateDebut) && (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-32 text-sm text-zinc-400">Début procédure</div>
              <div class="text-sm text-zinc-700">{formatDate(affaire.dateDebut)}</div>
            </div>
          )}
          {formatDate(affaire.dateVerdict) && (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-32 text-sm text-zinc-400">Verdict</div>
              <div class="text-sm text-zinc-700 font-medium">{formatDate(affaire.dateVerdict)}</div>
            </div>
          )}
          {affaire.appel && (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-32 text-sm text-zinc-400">Appel</div>
              <div class="text-sm text-zinc-700">{affaire.appel === 'oui' ? 'En cours' : 'Non'}</div>
            </div>
          )}
        </div>
      </div>

      <!-- Description -->
      <div class="card p-6 sm:p-8 mb-8">
        <h2 class="text-lg font-semibold text-zinc-900 mb-4">Résumé</h2>
        <div class="prose prose-zinc max-w-none text-sm leading-relaxed text-zinc-700 whitespace-pre-line">
          {affaire.description}
        </div>
      </div>

      <!-- Sentence (if condemned) -->
      {isC && (
        <div class="card p-6 sm:p-8 border-red-200 bg-red-50/30 mb-8">
          <h2 class="text-lg font-semibold text-red-800 mb-4">Peine prononcée</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {formatMoney(affaire.amende) && (
              <div>
                <span class="text-xs text-red-600/70">Amende</span>
                <p class="font-bold text-red-700">{formatMoney(affaire.amende)}</p>
              </div>
            )}
            {formatDuration(affaire.prison) && (
              <div>
                <span class="text-xs text-red-600/70">Prison</span>
                <p class="font-bold text-red-700">{formatDuration(affaire.prison)}</p>
              </div>
            )}
            {affaire.prisonSursis && (
              <div>
                <span class="text-xs text-red-600/70">Sursis</span>
                <p class="font-bold text-red-700">{affaire.prisonSursis}</p>
              </div>
            )}
            {formatDuration(affaire.ineligibilite) && (
              <div>
                <span class="text-xs text-red-600/70">Inéligibilité</span>
                <p class="font-bold text-red-700">{formatDuration(affaire.ineligibilite)}</p>
              </div>
            )}
            {affaire.tig && (
              <div>
                <span class="text-xs text-red-600/70">TIG</span>
                <p class="font-bold text-red-700">{affaire.tig} heures</p>
              </div>
            )}
          </div>
          {affaire.peine && (
            <div class="mt-4 pt-4 border-t border-red-200">
              <p class="text-sm text-red-700">{affaire.peine}</p>
            </div>
          )}
          {affaire.autresPeines && (
            <div class="mt-2">
              <p class="text-sm text-red-600/80">{affaire.autresPeines}</p>
            </div>
          )}
        </div>
      )}

      <!-- Source -->
      <div class="card p-5">
        <h2 class="text-sm font-semibold text-zinc-900 mb-3">Sources</h2>
        <div class="space-y-2">
          {affaire.premiereSourceUrl && (
            <a
              href={affaire.premiereSourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-blue-600 hover:text-blue-800 underline"
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              {affaire.premiereSourceTitre || 'Source'}
            </a>
          )}
          {affaire.pagePoligraph && (
            <a
              href={affaire.pagePoligraph}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-zinc-500 hover:text-zinc-700 underline"
            >
              Voir sur Poligraph
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </main>
</Layout>
