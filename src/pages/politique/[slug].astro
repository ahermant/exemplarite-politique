---
import Layout from '../../components/Layout.astro';
import AffairCard from '../../components/AffairCard.astro';
import { getPoliticiens, getPoliticienBySlug, getAffairesByPoliticienSlug } from '../../lib/data';
import { getPartyColor, getStatutLabel, getStatutVariant, isCondamnation, isInculpation, isEnquete, isRelaxeOuClassement } from '../../lib/types';

export function getStaticPaths() {
  const politiciens = getPoliticiens().filter(p => p.nbAffaires > 0);
  return politiciens.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const politicien = getPoliticienBySlug(slug);

if (!politicien) {
  return new Response(null, { status: 302, headers: { Location: '/' } });
}

const toutesAffaires = getAffairesByPoliticienSlug(slug);
const affaires = toutesAffaires.filter(a => a.implicationCode === 'DIRECT');
const partyColor = getPartyColor(politicien.parti);
const initials = ((politicien.prenom?.[0] || '') + (politicien.nom?.[0] || '')).toUpperCase() || '?';

const enquetes = affaires.filter(a => isEnquete(a.statutCode));
const inculpations = affaires.filter(a => isInculpation(a.statutCode));
const condamnations = affaires.filter(a => isCondamnation(a.statutCode));
const relaxe = affaires.filter(a => isRelaxeOuClassement(a.statutCode));

function formatDate(d) {
  if (!d) return null;
  try {
    const date = new Date(d);
    if (isNaN(date.getTime())) return d;
    return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch { return d; }
}
---

<Layout title={`${politicien.prenom} ${politicien.nom}`} description={`Affaires judiciaires de ${politicien.prenom} ${politicien.nom} — ${politicien.nbAffaires} affaire${politicien.nbAffaires > 1 ? 's' : ''}`}>
  <main class="flex-1">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Back -->
      <a href="/" class="inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-900 transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour
      </a>

      <!-- Profile Header -->
      <div class="card p-6 sm:p-8 mb-8">
        <div class="flex flex-col sm:flex-row items-start gap-6">
          <div
            class="flex-shrink-0 w-20 h-20 sm:w-24 sm:h-24 rounded-2xl flex items-center justify-center text-white font-bold text-2xl sm:text-3xl"
            style={`background-color: ${partyColor}`}
          >
            {initials}
          </div>
          <div class="flex-1 min-w-0">
            <h1 class="text-2xl sm:text-3xl font-bold text-zinc-900">
              {politicien.civilite ? `${politicien.civilite} ` : ''}{politicien.prenom} {politicien.nom}
            </h1>
            <div class="flex flex-wrap items-center gap-2 mt-2">
              {politicien.parti && (
                <span class="badge text-xs" style={`background-color: ${partyColor}15; color: ${partyColor}`}>
                  {politicien.parti}
                </span>
              )}
              {politicien.partiComplet && (
                <span class="text-sm text-zinc-500">{politicien.partiComplet}</span>
              )}
            </div>
            <p class="mt-2 text-zinc-600">
              {politicien.titreMandat || politicien.mandat}
              {politicien.circonscription && <span class="text-zinc-400"> &middot; {politicien.circonscription}</span>}
            </p>
            {politicien.profilUrl && (
              <a
                href={politicien.profilUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 mt-3 text-xs text-zinc-400 hover:text-zinc-600 underline"
              >
                Voir le profil Poligraph
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            )}
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-5 gap-3 mt-8 pt-6 border-t border-zinc-100">
          <button data-filter="all" class="filter-stat text-center cursor-pointer rounded-xl p-3 transition-all border-2 border-zinc-900 bg-zinc-900 text-white">
            <div class="text-2xl font-bold">{affaires.length}</div>
            <div class="text-xs text-white/70 mt-1 font-medium uppercase tracking-wide">Toutes</div>
          </button>
          <button data-filter="enquetes" class="filter-stat text-center cursor-pointer rounded-xl p-3 transition-all border-2 border-transparent hover:border-blue-200 hover:bg-blue-50">
            <div class={`text-2xl font-bold ${enquetes.length > 0 ? 'text-blue-600' : 'text-zinc-300'}`}>
              {enquetes.length}
            </div>
            <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wide">Enquêtes</div>
          </button>
          <button data-filter="inculpations" class="filter-stat text-center cursor-pointer rounded-xl p-3 transition-all border-2 border-transparent hover:border-amber-200 hover:bg-amber-50">
            <div class={`text-2xl font-bold ${inculpations.length > 0 ? 'text-amber-600' : 'text-zinc-300'}`}>
              {inculpations.length}
            </div>
            <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wide">Mises en examen</div>
          </button>
          <button data-filter="condamnations" class="filter-stat text-center cursor-pointer rounded-xl p-3 transition-all border-2 border-transparent hover:border-red-200 hover:bg-red-50">
            <div class={`text-2xl font-bold ${condamnations.length > 0 ? 'text-red-600' : 'text-zinc-300'}`}>
              {condamnations.length}
            </div>
            <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wide">Condamnations</div>
          </button>
          <button data-filter="relaxe" class="filter-stat text-center cursor-pointer rounded-xl p-3 transition-all border-2 border-transparent hover:border-green-200 hover:bg-green-50">
            <div class={`text-2xl font-bold ${relaxe.length > 0 ? 'text-green-600' : 'text-zinc-300'}`}>
              {relaxe.length}
            </div>
            <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wide">Relaxe/Classé</div>
          </button>
        </div>
      </div>

      <!-- Affairs -->
      <h2 class="text-xl font-bold text-zinc-900 mb-4" id="affaires-title">
        Affaires (<span id="affaires-count">{affaires.length}</span>)
      </h2>

      {affaires.length === 0 ? (
        <div class="card p-12 text-center">
          <p class="text-zinc-400">Aucune affaire recensée.</p>
        </div>
      ) : (
        <div id="affaires-list" class="space-y-3">
          {affaires.map(a => (
            <a
              href={`/affaire/${a.slug}`}
              class="affaire-item affaire-card block p-5 group"
              data-statut={a.statutCode}
            >
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
                <h3 class="font-semibold text-zinc-900 group-hover:text-blue-600 transition-colors">
                  {a.titre}
                </h3>
                <span class={`badge self-start flex-shrink-0 ${getStatutVariant(a.statutCode)}`}>
                  {getStatutLabel(a.statutCode)}
                </span>
              </div>
              <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-500">
                {a.categorie && <span>{a.categorie}</span>}
                {a.gravite && <span>Gravité : {a.gravite}</span>}
                {formatDate(a.dateDebut) && <span>Début : {formatDate(a.dateDebut)}</span>}
                {formatDate(a.dateVerdict) && <span>Verdict : {formatDate(a.dateVerdict)}</span>}
              </div>
              {a.peine && (
                <p class="mt-2 text-sm text-red-600 font-medium">{a.peine}</p>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </main>

  <script>
    const filterBtns = document.querySelectorAll('.filter-stat');
    const affaireItems = document.querySelectorAll('.affaire-item');
    const countEl = document.getElementById('affaires-count');

    const isEnquete = (code) => code === 'ENQUETE_PRELIMINAIRE';
    const isInculpation = (code) => code === 'MISE_EN_EXAMEN' || code === 'INSTRUCTION' || code === 'RENVOI_TRIBUNAL' || code === 'PROCES_EN_COURS';
    const isCondamnation = (code) => code === 'CONDAMNATION_PREMIERE_INSTANCE' || code === 'CONDAMNATION_DEFINITIVE' || code === 'APPEL_EN_COURS';
    const isRelaxe = (code) => code === 'RELAXE' || code === 'CLASSEMENT_SANS_SUITE' || code === 'NON_LIEU' || code === 'PRESCRIPTION';

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        filterBtns.forEach(b => {
          b.classList.remove('border-zinc-900', 'bg-zinc-900', 'text-white', 'border-blue-200', 'bg-blue-50', 'border-amber-200', 'bg-amber-50', 'border-red-200', 'bg-red-50', 'border-green-200', 'bg-green-50');
          b.classList.add('border-transparent');
          b.querySelector('div:last-child')?.classList.remove('text-white/70');
          b.querySelector('div:last-child')?.classList.add('text-zinc-500');
        });

        btn.classList.remove('border-transparent');
        if (filter === 'all') {
          btn.classList.add('border-zinc-900', 'bg-zinc-900', 'text-white');
          btn.querySelector('div:last-child')?.classList.add('text-white/70');
        } else if (filter === 'enquetes') {
          btn.classList.add('border-blue-200', 'bg-blue-50');
        } else if (filter === 'inculpations') {
          btn.classList.add('border-amber-200', 'bg-amber-50');
        } else if (filter === 'condamnations') {
          btn.classList.add('border-red-200', 'bg-red-50');
        } else if (filter === 'relaxe') {
          btn.classList.add('border-green-200', 'bg-green-50');
        }

        let visible = 0;
        affaireItems.forEach(item => {
          const code = item.dataset.statut;
          let show = filter === 'all';
          if (!show && filter === 'enquetes') show = isEnquete(code);
          if (!show && filter === 'inculpations') show = isInculpation(code);
          if (!show && filter === 'condamnations') show = isCondamnation(code);
          if (!show && filter === 'relaxe') show = isRelaxe(code);
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        countEl.textContent = visible;
      });
    });
  </script>
</Layout>
