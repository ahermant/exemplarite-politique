---
import type { StatsGlobale } from '../lib/types';

interface Props {
  stats: StatsGlobale;
}

const { stats } = Astro.props;
---

<div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
  <div class="flex items-center gap-2">
    <span class="text-zinc-400">Élus avec parti</span>
    <span class="font-bold text-zinc-900 tabular-nums">{stats.totalPoliticiens.toLocaleString('fr-FR')}</span>
  </div>
  <span class="text-zinc-300">|</span>
  <div class="flex items-center gap-2">
    <span class="text-2xl font-bold text-zinc-900 tabular-nums">{stats.totalAffaires}</span>
    <span class="text-zinc-400">affaires</span>
  </div>
  <span class="text-zinc-300">:</span>
  <span class="inline-flex items-center gap-1">
    <span class="w-2 h-2 rounded-full bg-blue-500"></span>
    <span class="font-semibold text-blue-700 tabular-nums">{stats.totalEnquetes}</span>
    <span class="text-zinc-500">enquêtes</span>
  </span>
  <span class="text-zinc-300">·</span>
  <span class="inline-flex items-center gap-1">
    <span class="w-2 h-2 rounded-full bg-amber-500"></span>
    <span class="font-semibold text-amber-700 tabular-nums">{stats.totalInculpations}</span>
    <span class="text-zinc-500">mises en examen</span>
  </span>
  <span class="text-zinc-300">·</span>
  <span class="inline-flex items-center gap-1">
    <span class="w-2 h-2 rounded-full bg-red-500"></span>
    <span class="font-semibold text-red-700 tabular-nums">{stats.totalCondamnations}</span>
    <span class="text-zinc-500">condamnations</span>
  </span>
  <span class="text-zinc-300">·</span>
  <span class="inline-flex items-center gap-1">
    <span class="w-2 h-2 rounded-full bg-green-500"></span>
    <span class="font-semibold text-green-700 tabular-nums">{stats.totalRelaxe}</span>
    <span class="text-zinc-500">relaxe/classé</span>
  </span>
</div>
