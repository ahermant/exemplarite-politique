---
import type { AffaireResume } from '../lib/types';
import { getStatutLabel, getStatutVariant } from '../lib/types';

interface Props {
  affaire: AffaireResume;
}

const { affaire: a } = Astro.props;
const variantClass = getStatutVariant(a.statutCode);
---

<a href={`/affaire/${a.slug}`} class="affaire-card block p-5 group">
  <div class="flex items-start justify-between gap-3 mb-2">
    <h4 class="font-medium text-sm text-zinc-900 group-hover:text-blue-600 transition-colors leading-snug">
      {a.titre || 'Affaire sans titre'}
    </h4>
    <span class={`badge flex-shrink-0 ${variantClass}`}>
      {getStatutLabel(a.statutCode)}
    </span>
  </div>
  <p class="text-xs text-zinc-500 mb-1">
    <span class="font-medium text-zinc-600">{a.categorie || '—'}</span>
    {a.gravite && <span class="ml-2">Gravité : {a.gravite}</span>}
  </p>
  {a.peine && (
    <p class="text-xs text-red-600 mt-2 font-medium">Peine : {a.peine}</p>
  )}
</a>
